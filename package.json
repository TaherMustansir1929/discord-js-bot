{
  "name": "discord-bot",
  "version": "0.1.0",
  "description": "Discord bot with goals and expense tracking",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
